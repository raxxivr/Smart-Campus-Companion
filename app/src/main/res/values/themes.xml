<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SmartCampusCompanion" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <!-- Use a transparent icon for the system splash screen to avoid the "double logo" effect -->
        <!-- The custom Compose SplashScreen will handle the main visual -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.SmartCampusCompanion</item>
    </style>
</resources>
